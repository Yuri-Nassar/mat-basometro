Criando a função para identifcar

```{r}
detectar_siglas_estados <- function(textos, estados_df) {
  textos <- tolower(textos)
  nomes_siglas <- tolower(c(estados_df$nome, estados_df$sigla))
  siglas_correspondentes <- c(estados_df$sigla, estados_df$sigla)  # manter sigla para nomes e siglas

  purrr::map_chr(textos, function(t) {
    encontrados <- nomes_siglas[stringr::str_detect(t, paste0("\\b", nomes_siglas, "\\b"))]
    siglas_encontradas <- unique(siglas_correspondentes[nomes_siglas %in% encontrados])
    if (length(siglas_encontradas) == 0) return(NA_character_)
    paste(siglas_encontradas, collapse = "; ")
  })
}
```

