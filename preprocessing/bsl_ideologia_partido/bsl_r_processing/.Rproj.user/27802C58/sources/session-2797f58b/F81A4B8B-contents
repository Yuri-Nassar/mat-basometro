Criar uma função para fazer essa categorização

```{r}
categorizar_curso <- function(texto, dicionario) {
  categoria <- purrr::map_chr(names(dicionario), function(padrao) {
    if (stringr::str_detect(texto, padrao)) return(dicionario[[padrao]])
    else return(NA_character_)
  })
  first_match <- categoria[!is.na(categoria)][1]
  ifelse(is.na(first_match), "Outros", first_match)
}

```

