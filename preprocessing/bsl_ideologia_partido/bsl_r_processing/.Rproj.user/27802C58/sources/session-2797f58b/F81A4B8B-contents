#selectionando as variáveis
unv_ceps <- unv %>% select(numero_identificacao_inscricao,cep_limpo) %>% mutate(cep_limpo = as.numeric(cep_limpo))


#isso aqui ainda não bateu
 unv_ceps <- fuzzy_left_join(
   unv_ceps, ceps_clean,
   by = c("cep_limpo" = "cep_de", "cep_limpo" = "cep_ate"),
   match_fun = list(`>=`, `<=`)
 )
 

 #Só selecionar casos unicos
 unv_ceps <- unv_ceps %>% unique()
 
 #criando a variável de robustez
 unv_ceps <- unv_ceps %>% mutate(cep_limpo_num = as.numeric(cep_limpo)) %>% #transformei em numerico
                         mutate(cep_maior = if_else(cep_limpo_num >= cep_de , 1,0)) %>% #condição de ser maior
                         mutate(cep_menor = if_else(cep_limpo_num <= cep_ate , 1,0)) %>% #e menor
                        mutate(cep_soma = cep_menor + cep_maior)  #somei
 
 unv_ceps_limpos <- unv_ceps %>% filter(cep_soma == 2) %>% unique() #filtrei dos menores que 2
 
 
```

