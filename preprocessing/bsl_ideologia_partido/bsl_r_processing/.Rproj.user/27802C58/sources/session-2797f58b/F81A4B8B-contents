```{r}
categorizar_multiplas_binarias <- function(df, coluna_texto, dicionario) {
  
  # Garante que o texto esteja limpo: minúsculo e sem acentos
  df <- df %>%
    mutate(.texto_limpo = !!sym(coluna_texto) %>%
             str_to_lower() %>%
             stri_trans_general("Latin-ASCII"))
  
  # Pega os nomes únicos das categorias
  categorias <- unique(dicionario)
  
  # Cria as colunas binarias por categoria (agrupando padrões)
  df_binarias <- map_dfc(categorias, function(cat) {
    padroes <- names(dicionario)[dicionario == cat]
    tibble(!!cat := as.integer(str_detect(df$.texto_limpo, str_c(padroes, collapse = "|"))))
  })

  # Junta com o original (sem a coluna temporária)
  df %>%
    select(-.texto_limpo) %>%
    bind_cols(df_binarias)
}

```

