      ufs_1 <- str_split(uf_end_jp, ",")[[1]] %>% str_trim()
      ufs_2 <- str_split(UF, ",")[[1]] %>% str_trim()
      ufs_3 <- str_split(uf_cep, ",")[[1]] %>% str_trim()
      
      # Checar as interseções entre as UFs
      inters_12 <- length(intersect(ufs_1, ufs_2)) > 0
      inters_13 <- length(intersect(ufs_1, ufs_3)) > 0
      inters_23 <- length(intersect(ufs_2, ufs_3)) > 0
      
      soma <- sum(c(inters_12, inters_13, inters_23))
      
      # Classificar de acordo com o número de interseções
      if (soma == 3) {
        "todas conferem"
      } else if (soma == 2) {
        "duas conferem"
      } else {
        "nenhuma confere"
      }
    }
  ) %>%
  ungroup()
# Resultado final

